APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173

# Dev-only mock login for the 3 demo accounts.
# Staging/production must set this to false.
AUTH_MOCK_ENABLED=true

JWT_SECRET=dev-only-change-me-please
SECRET_ENCRYPTION_KEY=

DATABASE_URL=postgresql+asyncpg://vsf:vsf@localhost:5432/vsf_annotation
DATABASE_URL_SYNC=postgresql+psycopg://vsf:vsf@localhost:5432/vsf_annotation
REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vsf-pdf
S3_REGION=us-east-1
