# ──────────────────────────────────────────────
# VSF AI Annotation Platform — Backend env template
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit file .env vào git.
# ──────────────────────────────────────────────

# ---- App / runtime ----
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ---- Auth / security ----
# Tạo secret ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=7
AUTH_MOCK_ENABLED=false

# Khóa Fernet để mã hóa LLM API key at-rest (BR-1.2)
# Tạo: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=CHANGE_ME

# ---- Database (Supabase Shared Pooler — IPv4 compatible) ----
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ---- Supabase ----
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# ---- Redis (Render Redis free tier hoặc Upstash) ----
REDIS_URL=redis://localhost:6379/0

# ---- Storage ----
# "s3" cho Supabase Storage / S3 — "local" chỉ dùng dev local
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://PROJECT_REF.supabase.co/storage/v1/s3
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=vsf-pdf
S3_REGION=ap-southeast-1

# ---- LLM provider (OQ-002 chưa chốt) ----
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_PROMPT_VERSION=pre_score_v1

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=console
