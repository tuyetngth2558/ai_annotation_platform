# Frontend (Vite) env template — copy thành .env.local cho dev.
# Trên Vercel: đặt các biến này ở Project Settings → Environment Variables.
# Vite chỉ expose biến có tiền tố VITE_ ra client bundle.

# URL gốc của API backend (KHÔNG có /api/v1 ở cuối — apiClient tự nối).
# Dev:  http://localhost:8000
# Prod: https://vsf-api.onrender.com   (đổi theo URL Render thật của bạn)
VITE_API_BASE_URL=http://localhost:8000
